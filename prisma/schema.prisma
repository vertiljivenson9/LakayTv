// LakayTV - Plateforme de Streaming Haïtien
// Schema de Base de Données

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== UTILISATEURS ====================

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  image         String?
  role          UserRole    @default(VIEWER)
  authProvider  AuthProvider
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  subscriptions Subscription[]
  watchHistory  WatchHistory[]
  favorites     Favorite[]
  contents      Content[]     @relation("ProducerContent")
  transactions  Transaction[]

  @@map("users")
}

enum UserRole {
  VIEWER
  PRODUCER
  ADMIN
}

enum AuthProvider {
  GOOGLE
  MICROSOFT
}

// ==================== CONTENU ====================

model Content {
  id            String        @id @default(cuid())
  title         String
  description   String?
  type          ContentType
  language      Language
  duration      Int           // en minutes
  thumbnailUrl  String?
  videoUrl      String        // URL Telegram ou CDN
  trailerUrl    String?
  price         Float?        // Prix optionnel pour location
  releaseYear   Int?
  rating        Float?        @default(0)
  viewCount     Int           @default(0)
  status        ContentStatus @default(PENDING)
  quality       VideoQuality  @default(FHD)
  producerId    String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  producer      User          @relation("ProducerContent", fields: [producerId], references: [id])
  seasons       Season[]
  genres        ContentGenre[]
  watchHistory  WatchHistory[]
  favorites     Favorite[]

  @@map("contents")
}

enum ContentType {
  MOVIE
  SERIES
  TRAILER
}

enum Language {
  FRENCH
  CREOLE
  BOTH
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VideoQuality {
  HD      // 720p - minimum acceptable
  FHD     // 1080p - standard
  QHD     // 1440p
  UHD     // 2160p (4K)
}

// ==================== SÉRIES ====================

model Season {
  id          String      @id @default(cuid())
  number      Int
  title       String?
  contentId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  content     Content     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes    Episode[]

  @@unique([contentId, number])
  @@map("seasons")
}

model Episode {
  id          String    @id @default(cuid())
  number      Int
  title       String
  duration    Int       // en minutes
  videoUrl    String
  thumbnailUrl String?
  seasonId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  season      Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, number])
  @@map("episodes")
}

// ==================== GENRES ====================

model Genre {
  id          String        @id @default(cuid())
  name        String        @unique
  nameFr      String
  createdAt   DateTime      @default(now())

  // Relations
  contents    ContentGenre[]

  @@map("genres")
}

model ContentGenre {
  contentId   String
  genreId     String

  // Relations
  content     Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  genre       Genre     @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([contentId, genreId])
  @@map("content_genres")
}

// ==================== SOUSCRIPTIONS ====================

model Subscription {
  id          String            @id @default(cuid())
  userId      String
  plan        SubscriptionPlan
  status      SubscriptionStatus
  amount      Float
  currency    Currency
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  user        User              @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionPlan {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum Currency {
  HTG
  USD
  EUR
}

// ==================== TRANSACTIONS ====================

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  amount      Float
  currency    Currency
  type        TransactionType
  status      TransactionStatus
  description String?
  metadata    String?           // JSON pour données additionnelles
  createdAt   DateTime          @default(now())

  // Relations
  user        User              @relation(fields: [userId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  SUBSCRIPTION
  RENTAL
  COMMISSION
  PAYOUT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ==================== HISTORIQUE & FAVORIS ====================

model WatchHistory {
  id          String    @id @default(cuid())
  userId      String
  contentId   String
  progress    Int       @default(0)  // pourcentage de progression
  completed   Boolean   @default(false)
  watchedAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("watch_history")
}

model Favorite {
  id          String    @id @default(cuid())
  userId      String
  contentId   String
  createdAt   DateTime  @default(now())

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("favorites")
}

// ==================== MODÉRATION ====================

model ModerationLog {
  id          String          @id @default(cuid())
  contentId   String
  adminId     String
  action      ModerationAction
  reason      String?
  createdAt   DateTime        @default(now())

  @@map("moderation_logs")
}

enum ModerationAction {
  APPROVED
  REJECTED
  SUSPENDED
  EDITED
}
